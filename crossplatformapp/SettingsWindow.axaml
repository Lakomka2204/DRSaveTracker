<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="using:crossplatformapp"
        mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="200"
        x:Class="crossplatformapp.SettingsWindow"
        WindowStartupLocation="CenterOwner"
        Width="600"
        Height="300"
        CanMaximize="False"
        CanMinimize="False"
        x:DataType="local:SettingsViewModel"
        Title="Settings"
        >
        <StackPanel Orientation="Vertical">
            <TextBlock 
            Text="Settings"
FontFamily="{StaticResource ResourceKey=DRFontFamily}"
FontWeight="Bold"
FontSize="24"
Margin="10,5"
            />
            <StackPanel Margin="20,10">

                <TextBlock
                FontFamily="{StaticResource ResourceKey=DRFontFamily}"
                Text="Run on system startup"
                />
                <TextBlock
                FontFamily="{StaticResource ResourceKey=DRFontFamily}"
                IsVisible="{Binding IsStartupLocked}"
                Text="(disabled by user)"
                />
                <ToggleSwitch 
                IsEnabled="{Binding !IsStartupLocked}"
                IsChecked="{Binding Path=IsStartupEnabled, Mode=TwoWay}"
                FontFamily="{StaticResource ResourceKey=DRFontFamily}"
                >
                
                </ToggleSwitch>
            </StackPanel>
            <StackPanel Margin="20,10">

                <TextBlock
                FontFamily="{StaticResource ResourceKey=DRFontFamily}"
                Text="Hide in system tray on close"
                />
                <ToggleSwitch 
                IsChecked="{Binding Path=Settings.HideOnClose, Mode=TwoWay}"
                FontFamily="{StaticResource ResourceKey=DRFontFamily}"
                >
                </ToggleSwitch>
            </StackPanel>
        </StackPanel>
</Window>